#!/bin/sh
#
# Purpose:
#       download the Tumor Allele ID Report
#
# full url:
# https://tumor.informatics.jax.org/mtbwi/alleleIDReport.do
#
# products:
#       femover
#
# HISTORY
#
comment="femover"
REMOTE_SITE=tumor.informatics.jax.org
REMOTE_SITE_URL=https://$REMOTE_SITE
REMOTE_DIR=/mtbwi
REMOTE_FILES="alleleIDReport.do"
WGET_OPTIONS="--no-parent -S -t 10 -nd -m --no-check-certificate"
local_dir_check=true
do_deletes=true
recursive=false
